  <div style={{
    background: "rgba(255,255,255,0.7)",
    border: "1px solid rgba(0,0,0,0.07)",
    borderRadius: 10,
    padding: "10px 14px",
    backdropFilter: "blur(4px)",
  }}>
    <div style={{ fontSize: 10, fontWeight: 600, letterSpacing: "0.1em", color: accent || "#A08040", textTransform: "uppercase", marginBottom: 3 }}>
      {label}
    </div>
    <div style={{ fontSize: 13, fontWeight: 600, color: "#1A1A1A", lineHeight: 1.3 }}>
      {value}
    </div>
  </div>
);

