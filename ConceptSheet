import { useState, useEffect } from "react";

// ─── Melawood colour map (Supamatt range) ────────────────────────────────────
const MELAWOOD_COLOURS = {
  "Supamatt Natural Oak":   { hex: "#C8A97A", texture: "wood" },
  "Supamatt White":         { hex: "#F2EFE9", texture: "matte" },
  "Supamatt Charcoal":      { hex: "#3C3C3C", texture: "matte" },
  "Supamatt Dove Grey":     { hex: "#B8B3AC", texture: "matte" },
  "Supamatt Sage":          { hex: "#9EAD96", texture: "matte" },
  "Supagloss Arctic White": { hex: "#EEECEA", texture: "gloss" },
  "Supagloss Graphite":     { hex: "#4A4A4A", texture: "gloss" },
  "Wood Grain Walnut":      { hex: "#6B4A2A", texture: "wood" },
  "Wood Grain Wenge":       { hex: "#3B2A1E", texture: "wood" },
};

const COUNTERTOP_COLOURS = {
  "Engineered Quartz — Calacatta Marble finish": { hex: "#EDE9E1", vein: "#C8C0B8", label: "Calacatta" },
  "Engineered Quartz — Midnight Black":           { hex: "#1A1A1A", vein: "#2E2E2E", label: "Midnight Black" },
  "Engineered Quartz — Concrete Grey":            { hex: "#8F8F8A", vein: "#7A7A75", label: "Concrete Grey" },
  "Solid Oak Timber":                             { hex: "#C49A5A", vein: "#A8803A", label: "Solid Oak" },
  "Dekton Ultracompact":                          { hex: "#D4CFC8", vein: "#B8B0A8", label: "Dekton" },
};

// ─── Wood grain SVG pattern ───────────────────────────────────────────────────
const WoodPattern = ({ colour }) => (
  <svg width="0" height="0" style={{ position: "absolute" }}>
    <defs>
      <pattern id="wood-grain" x="0" y="0" width="120" height="8" patternUnits="userSpaceOnUse">
        <rect width="120" height="8" fill={colour} />
        <line x1="0" y1="2" x2="120" y2="2.5" stroke="rgba(0,0,0,0.06)" strokeWidth="0.8" />
        <line x1="0" y1="5" x2="120" y2="4.5" stroke="rgba(0,0,0,0.04)" strokeWidth="0.5" />
        <line x1="0" y1="7" x2="120" y2="6.8" stroke="rgba(255,255,255,0.05)" strokeWidth="0.4" />
      </pattern>
      <pattern id="gloss-grain" x="0" y="0" width="60" height="60" patternUnits="userSpaceOnUse">
        <rect width="60" height="60" fill={colour} />
        <circle cx="30" cy="30" r="28" fill="none" stroke="rgba(255,255,255,0.08)" strokeWidth="1" />
        <rect x="5" y="5" width="50" height="50" rx="2" fill="none" stroke="rgba(255,255,255,0.05)" strokeWidth="0.5" />
      </pattern>
    </defs>
  </svg>
);

// ─── Cabinet swatch with realistic finish ────────────────────────────────────
const CabinetSwatch = ({ name, size = "lg" }) => {
  const colour = MELAWOOD_COLOURS[name] || { hex: "#C8A97A", texture: "wood" };
  const isWood = colour.texture === "wood";
  const isGloss = colour.texture === "gloss";
  const dim = size === "lg" ? 80 : 48;

  return (
    <div style={{ display: "flex", flexDirection: "column", alignItems: "center", gap: 6 }}>
      <WoodPattern colour={colour.hex} />
      <div style={{
        width: dim, height: dim,
        borderRadius: size === "lg" ? 12 : 8,
        background: isWood
          ? `url(#wood-grain) repeat`
          : isGloss
          ? `url(#gloss-grain) repeat`
          : colour.hex,
        backgroundColor: colour.hex,
        boxShadow: `inset 0 1px 2px rgba(255,255,255,0.2), inset 0 -1px 2px rgba(0,0,0,0.15), 0 2px 8px rgba(0,0,0,0.12)`,
        border: "1px solid rgba(0,0,0,0.08)",
        position: "relative",
        overflow: "hidden",
      }}>
        {isWood && (
          <svg width="100%" height="100%" style={{ position: "absolute", top: 0, left: 0 }}>
            {[2, 5, 9, 13, 17, 21, 26, 30, 35, 39, 44, 48, 53, 58, 63, 68, 73].map((y, i) => (
              <line key={i} x1="0" y1={y} x2={dim} y2={y + (Math.random() * 2 - 1)}
                stroke="rgba(0,0,0,0.055)" strokeWidth={i % 3 === 0 ? "0.9" : "0.5"} />
            ))}
            <rect width="100%" height="100%"
              fill="url(#wood-shimmer)" opacity="0.3" />
          </svg>
        )}
        {isGloss && (
          <div style={{
            position: "absolute", top: 0, left: 0, right: 0, height: "45%",
            background: "linear-gradient(180deg, rgba(255,255,255,0.22) 0%, rgba(255,255,255,0) 100%)",
            borderRadius: "inherit",
          }} />
        )}
      </div>
    </div>
  );
};

// ─── Countertop swatch with vein effect ──────────────────────────────────────
const CountertopSwatch = ({ name, size = "lg" }) => {
  const ct = COUNTERTOP_COLOURS[name] || COUNTERTOP_COLOURS["Engineered Quartz — Calacatta Marble finish"];
  const dim = size === "lg" ? 80 : 48;
  const isLight = parseInt(ct.hex.slice(1, 3), 16) > 128;

  return (
    <div style={{ display: "flex", flexDirection: "column", alignItems: "center", gap: 6 }}>
      <div style={{
        width: dim, height: dim,
        borderRadius: size === "lg" ? 12 : 8,
        background: ct.hex,
        boxShadow: `inset 0 1px 2px rgba(255,255,255,0.18), 0 2px 8px rgba(0,0,0,0.12)`,
        border: "1px solid rgba(0,0,0,0.08)",
        position: "relative",
        overflow: "hidden",
      }}>
        <svg width="100%" height="100%" style={{ position: "absolute", top: 0, left: 0 }} viewBox={`0 0 ${dim} ${dim}`}>
          {/* Marble veins */}
          <path d={`M${dim*0.1},0 Q${dim*0.3},${dim*0.25} ${dim*0.2},${dim*0.5} Q${dim*0.35},${dim*0.75} ${dim*0.15},${dim}`}
            stroke={ct.vein} strokeWidth="1.2" fill="none" opacity="0.6" />
          <path d={`M${dim*0.5},0 Q${dim*0.7},${dim*0.3} ${dim*0.6},${dim*0.6} Q${dim*0.8},${dim*0.8} ${dim*0.7},${dim}`}
            stroke={ct.vein} strokeWidth="0.7" fill="none" opacity="0.4" />
          <path d={`M${dim*0.75},${dim*0.1} Q${dim*0.9},${dim*0.4} ${dim*0.85},${dim*0.7}`}
            stroke={ct.vein} strokeWidth="0.5" fill="none" opacity="0.3" />
        </svg>
        <div style={{
          position: "absolute", top: 0, left: 0, right: 0, height: "40%",
          background: `linear-gradient(180deg, rgba(255,255,255,${isLight ? 0.15 : 0.08}) 0%, rgba(255,255,255,0) 100%)`,
        }} />
      </div>
    </div>
  );
};

