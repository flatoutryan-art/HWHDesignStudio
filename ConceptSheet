  return (
    <svg viewBox="0 0 360 200" xmlns="http://www.w3.org/2000/svg" style={{ width: "100%", borderRadius: 12, ...style }}>
      {/* Background wall */}
      <rect width="360" height="200" fill="#F5F0E8" rx="12" />

      {/* ── Wall cabinets (upper left) ── */}
      <rect x="20" y="18" width="110" height="68" rx="4" fill={cab.hex} />
      <rect x="22" y="20" width="52" height="64" rx="3" fill={cab.hex} stroke={doorLine} strokeWidth="1" />
      <rect x="76" y="20" width="52" height="64" rx="3" fill={cab.hex} stroke={doorLine} strokeWidth="1" />
      <circle cx="48" cy="52" r="3" fill="rgba(180,150,100,0.7)" />
      <circle cx="102" cy="52" r="3" fill="rgba(180,150,100,0.7)" />

      {/* ── Wall cabinets (upper right — island overhead) ── */}
      <rect x="190" y="18" width="150" height="68" rx="4" fill={cab.hex} />
      <rect x="192" y="20" width="72" height="64" rx="3" fill={cab.hex} stroke={doorLine} strokeWidth="1" />
      <rect x="266" y="20" width="72" height="64" rx="3" fill={cab.hex} stroke={doorLine} strokeWidth="1" />
      <circle cx="228" cy="52" r="3" fill="rgba(180,150,100,0.7)" />
      <circle cx="302" cy="52" r="3" fill="rgba(180,150,100,0.7)" />

      {/* ── Countertop strip ── */}
      <rect x="12" y="90" width="336" height="8" rx="2" fill={ct.hex} />
      <rect x="12" y="90" width="336" height="2" rx="1" fill="rgba(255,255,255,0.3)" />

      {/* ── Base cabinets ── */}
      {[12, 82, 152, 222, 292].map((x, i) => (
        <g key={i}>
          <rect x={x} y="98" width="66" height="90" rx="3" fill={cab.hex} stroke={doorLine} strokeWidth="0.8" />
          <circle cx={x + 33} cy="143" r="3" fill="rgba(180,150,100,0.7)" />
        </g>
      ))}

      {/* ── Sink indication ── */}
      <rect x="82" y="100" width="64" height="30" rx="3" fill="rgba(200,215,225,0.5)" stroke="rgba(150,180,200,0.4)" strokeWidth="1" />
      <rect x="92" y="107" width="44" height="16" rx="2" fill="rgba(180,200,215,0.4)" />
      <circle cx="114" cy="96" r="3.5" fill="rgba(160,160,160,0.6)" />

      {/* ── Floor indication ── */}
      <rect x="0" y="188" width="360" height="12" rx="0" fill="rgba(190,185,178,0.5)" />
      {[30, 90, 150, 210, 270, 330].map((x, i) => (
        <line key={i} x1={x} y1="188" x2={x} y2="200" stroke="rgba(160,155,148,0.4)" strokeWidth="0.8" />
      ))}
    </svg>
  );
};

// ─── Spec pill component ──────────────────────────────────────────────────────
